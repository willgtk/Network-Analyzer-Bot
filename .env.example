# ==========================================
# Network Monitor — Variáveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha com os seus dados:
#   cp .env.example .env

# --- Telegram Bot (para receber alertas no celular) ---
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# --- Redes a monitorar (separadas por vírgula) ---
REDES_ALVO=192.168.1.1/24
GATEWAYS=192.168.1.1

# SSIDs opcionais (formato: rede=SSID, separados por vírgula)
# REDES_SSIDS=192.168.1.1/24=MinhaRede,192.168.2.1/24=RedeGuest

# --- IDS (Sniffer) ---
# Limite de requisições SYN por segundo para considerar Port Scan
# MAX_SYN_PER_SEC=20
# Máximo de pacotes na RAM antes de rotação automática
# MAX_PACOTES_RAM=50000

# --- Nível de Log: DEBUG, INFO, WARNING, ERROR ---
# LOG_LEVEL=INFO
